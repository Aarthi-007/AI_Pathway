# VITE_FEATHERLESS_API_KEY: Required for Featherless AI API calls.
# Get this from your Featherless provider dashboard.
# This is loaded by Vite as a client env variable
VITE_FEATHERLESS_API_KEY="featherless_api_key_placeholder"

# VITE_CLERK_PUBLISHABLE_KEY: Required for Clerk authentication
# Get this from your Clerk dashboard at https://dashboard.clerk.com
# Vite prefixed variables are automatically exposed to the frontend
VITE_CLERK_PUBLISHABLE_KEY="clerk_publishable_key_placeholder"

# CLERK_SECRET_KEY: Optional, used for backend Clerk operations
CLERK_SECRET_KEY="clerk_secret_key_placeholder"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
