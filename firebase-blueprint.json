{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Roadmap": {
      "title": "Learning Roadmap",
      "description": "A generated learning pathway for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "learningGoal": { "type": "string" },
        "level": { "type": "string" },
        "skills": { "type": "string" },
        "steps": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "videoUrl": { "type": "string", "description": "Optional Veo generated video URL" }
      },
      "required": ["userId", "learningGoal", "steps", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/roadmaps/{roadmapId}": {
      "schema": "Roadmap",
      "description": "Collection of generated roadmaps."
    }
  }
}
