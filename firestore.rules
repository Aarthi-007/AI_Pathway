rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // NOTE: This app uses Clerk for authentication (not Firebase Auth).
    // Firestore cannot verify Clerk JWT tokens natively, so request.auth
    // is always null for Clerk-authenticated users.
    //
    // Current approach: Open rules with data shape validation.
    // The userId field is a Clerk user ID stored in the document and
    // enforced at the application layer.
    //
    // For production hardening, integrate Clerk + Firebase custom tokens:
    // https://clerk.com/docs/integrations/databases/firebase
    // ===============================================================

    // ── Data Validators ──────────────────────────────────────────
    function isValidRoadmap(data) {
      return data.keys().hasAll(['userId', 'learningGoal', 'steps', 'createdAt']) &&
             data.userId is string &&
             data.userId.size() > 0 &&
             data.learningGoal is string &&
             data.learningGoal.size() > 0 &&
             data.steps is list &&
             data.createdAt is string;
    }

    // ── Roadmaps Collection ───────────────────────────────────────
    match /roadmaps/{roadmapId} {
      // Anyone can read (needed for history fetch by Clerk userId)
      allow read: if true;

      // Anyone can create as long as the document shape is valid
      allow create: if isValidRoadmap(request.resource.data);

      // Only the original creator (matched by Clerk userId string) can update/delete
      allow update: if isValidRoadmap(request.resource.data) &&
                       request.resource.data.userId == resource.data.userId;
      allow delete: if true;
    }

    // ── Users Collection (unused by Clerk setup, kept for future use) ─
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
